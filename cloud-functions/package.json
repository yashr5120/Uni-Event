{
  "name": "functions",
  "scripts": {
    "build": "tsc",
    "serve": "npm run build && firebase emulators:start --import=./emulator-data --export-on-exit=./emulator-data",
    "shell": "npm run build && firebase functions:shell",
    "start": "node lib/server.js",
    "deploy": "firebase deploy --only functions",
    "logs": "firebase functions:log",
    "lint": "eslint .",
    "format": "prettier --write ."
  },
  "engines": {
    "node": "18"
  },
  "main": "lib/index.js",
