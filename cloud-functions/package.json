    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "expo-server-sdk": "^4.0.0",
    "express": "^5.2.1",
    "firebase-admin": "^11.11.1",
    "firebase-functions": "~4.9.0",
    "pdf-lib": "^1.17.1",
    "resend": "^6.6.0"
  },
  "devDependencies": {
    "@types/markdown-it": "^14.1.2",
    "@types/cors": "^2.8.0",
    "@types/express": "^4.17.0",
    "firebase-functions-test": "^3.1.0",
